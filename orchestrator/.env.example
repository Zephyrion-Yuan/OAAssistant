# Copy to orchestrator/.env and fill in.

# Node executor backend (the existing OAAssistant service)
NODE_BASE_URL=http://127.0.0.1:8787

# Which executor the graph talks to: http-node | mock
EXECUTOR=http-node

# Platform hint for the Node backend launch strategy (informational; the graph
# itself is device-agnostic). win | mac
OA_PLATFORM=mac

# DeepSeek (understanding layer). Required only when EXECUTOR drives real LLM nodes.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Self-heal retry budget for the diagnose node
MAX_RETRIES=2
